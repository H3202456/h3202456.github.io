---

<section class="section contact-section" id="contact" data-animate>
  <div class="section-head">
    <p class="section-label">Contact</p>
    <h2>联系我</h2>
    <p>
      如果你想了解我的项目、作品集、AI Demo 记录，或者有合适的合作 / 实习 / 项目机会，可以通过下面方式联系我。
    </p>
  </div>

  <div class="contact-grid">
    {contacts.map((item) =>
      item.disabled ? (
        <div class="contact-card contact-card--disabled" aria-disabled="true">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
          <small>{item.note}</small>
        </div>
      ) : (
        <a
          class="contact-card contact-card--link"
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener noreferrer" : undefined}
          aria-label={`${item.label}: ${item.value}`}
        >
          <span>{item.label}</span>
          <strong>{item.value}</strong>
          <small>{item.note}</small>
        </a>
      )
    )}
  </div>

</section>