---

<section id="projects" class="section projects" data-animate>
  <div class="section-label">02 / Projects</div>

  <div class="section-heading">
    <h2>做过的项目</h2>
    <p>
      项目不是摆设，也不是“作品集坟场”。每个 Demo 都对应一次需求理解、一次实现训练、一次复盘。
    </p>
  </div>

  <div class="project-list">
    {projects.map((project, index) => (
      <article class="project-item" data-animate>
        <div class="project-index">{String(index + 1).padStart(2, "0")}</div>

        <div class="project-main">
          <h3>{project.title}</h3>
          <p>{project.desc}</p>

          <div class="tag-list">
            {project.tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>