<section id="projects" class="section projects" data-animate>
  <div class="section-label">02 / Projects</div>

  <div class="section-grid">
    <div>
      <h2>做过的项目</h2>
      <p class="section-side-note">
        我不会把所有文件夹都塞到首页。默认只展示最能代表当前方向的项目，其他项目先收起来。
        毕竟作品集不是硬盘目录，虽然人类经常分不清这两件事。
      </p>
    </div>

    <div class="projects-stack">
      <div class="project-list">
        {featuredProjects.map((project) => (
          <article class="project-card" data-animate>
            <div class="project-card-head">
              <h3>{project.title}</h3>
              <span>{project.status}</span>
            </div>

            <p>{project.desc}</p>

            <div class="project-tags">
              {project.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))}
      </div>

      <details class="more-projects">
        <summary>
          <span>查看更多项目</span>
          <small>{moreProjects.length} 个已隐藏</small>
        </summary>

        <div class="project-list more-project-list">
          {moreProjects.map((project) => (
            <article class="project-card project-card-secondary" data-animate>
              <div class="project-card-head">
                <h3>{project.title}</h3>
                <span>{project.status}</span>
              </div>

              <p>{project.desc}</p>

              <div class="project-tags">
                {project.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </details>
    </div>
  </div>
</section>